        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest AS (SELECT MAX(window_end) AS ts FROM contribution_windows WHERE ('${repo}' = '.*' OR repo = '${repo}') AND window_days = 30), ranked AS (SELECT module, actor, owner_share, ROW_NUMBER() OVER (PARTITION BY module ORDER BY owner_share DESC, actor) AS rn FROM contribution_windows, latest WHERE ('${repo}' = '.*' OR repo = '${repo}') AND window_days = 30 AND window_end = latest.ts), top1 AS (SELECT module, actor AS top_owner, owner_share AS top_owner_share FROM ranked WHERE rn = 1), top2 AS (SELECT module, actor AS second_owner, owner_share AS second_owner_share FROM ranked WHERE rn = 2) SELECT t1.module AS module, t1.top_owner AS top_owner, ROUND((t1.top_owner_share * 100)::numeric, 2) AS top_owner_share_pct, COALESCE(t2.second_owner, '-') AS second_owner, ROUND(((t1.top_owner_share - COALESCE(t2.second_owner_share, 0)) * 100)::numeric, 2) AS gap_pct FROM top1 t1 LEFT JOIN top2 t2 ON t1.module = t2.module ORDER BY gap_pct DESC, module ASC",
          "refId": "A"
        }
      ],
