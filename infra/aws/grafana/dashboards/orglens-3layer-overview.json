        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH selected_actor AS (SELECT CASE WHEN '${actor}' = '__AUTO__' OR '${actor}' = '' THEN (SELECT actor FROM contribution_windows WHERE ('${repo}' = '.*' OR repo = '${repo}') AND window_days = 30 GROUP BY actor ORDER BY SUM(weight) DESC NULLS LAST LIMIT 1) ELSE '${actor}' END AS actor), latest_window AS (SELECT repo, module, MAX(window_end) AS window_end FROM contribution_windows WHERE ('${repo}' = '.*' OR repo = '${repo}') AND window_days = 30 GROUP BY repo, module), dist AS (SELECT cw.module, cw.actor, cw.owner_share FROM contribution_windows cw JOIN latest_window w ON cw.repo = w.repo AND cw.module = w.module AND cw.window_end = w.window_end WHERE cw.window_days = 30), before_ranked AS (SELECT module, actor, owner_share, ROW_NUMBER() OVER (PARTITION BY module ORDER BY owner_share DESC, actor) AS rn, SUM(owner_share) OVER (PARTITION BY module ORDER BY owner_share DESC, actor ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS cum_share FROM dist), before_bf AS (SELECT module, MIN(rn) FILTER (WHERE cum_share >= 0.5) AS before_bus_factor FROM before_ranked GROUP BY module), filtered AS (SELECT module, actor, owner_share FROM dist WHERE actor <> (SELECT actor FROM selected_actor)), renorm AS (SELECT module, actor, owner_share / NULLIF(SUM(owner_share) OVER (PARTITION BY module), 0) AS owner_share FROM filtered), after_ranked AS (SELECT module, actor, owner_share, ROW_NUMBER() OVER (PARTITION BY module ORDER BY owner_share DESC, actor) AS rn, SUM(owner_share) OVER (PARTITION BY module ORDER BY owner_share DESC, actor ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS cum_share FROM renorm), after_bf AS (SELECT module, MIN(rn) FILTER (WHERE cum_share >= 0.5) AS after_bus_factor FROM after_ranked GROUP BY module), leaders AS (SELECT module, MAX(CASE WHEN rn = 1 THEN actor END) AS new_top_owner, MAX(CASE WHEN rn = 1 THEN owner_share END) AS new_top_share, MAX(CASE WHEN rn = 2 THEN actor END) AS second_owner, MAX(CASE WHEN rn = 2 THEN owner_share END) AS second_share FROM after_ranked GROUP BY module) SELECT b.module, (SELECT actor FROM selected_actor) AS removed_actor, b.before_bus_factor, a.after_bus_factor, (a.after_bus_factor - b.before_bus_factor) AS delta_bus_factor, CASE WHEN b.before_bus_factor > 1 AND a.after_bus_factor = 1 THEN true ELSE false END AS flips_to_critical, l.new_top_owner, ROUND((COALESCE(l.new_top_share, 0) * 100)::numeric, 2) AS new_top_owner_share_pct, COALESCE(l.second_owner, '-') AS second_owner, ROUND(((COALESCE(l.new_top_share, 0) - COALESCE(l.second_share, 0)) * 100)::numeric, 2) AS gap_pct FROM before_bf b JOIN after_bf a ON b.module = a.module LEFT JOIN leaders l ON b.module = l.module ORDER BY flips_to_critical DESC, delta_bus_factor ASC, gap_pct DESC, b.module ASC",
